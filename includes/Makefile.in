FILES=certs.mwn file.mwn grp.mwn http.mwn main.mwn sql.mwn\
	math.mwn net.mwn os.mwn ps.mwn pwd.mwn sysstat.mwn units.mwn \
	ansicolor.mwn
INCLUDEDIR=@INCLUDE@
INSTALL=install
OWNER=@OWNER@
GROUP=@GROUP@

dummy:

install: ${FILES}
	mkdir -p ${INCLUDEDIR}
	cp ${FILES} ${INCLUDEDIR}
	sudo chmod 755 ${INCLUDEDIR}
	sudo chmod 644 ${INCLUDEDIR}/*.mwn
clean:
	rm -f *~ \#*\#	

