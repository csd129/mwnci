FILES=certs.mwnci file.mwnci grp.mwnci http.mwnci main.mwnci sql.mwnci\
	math.mwnci net.mwnci os.mwnci ps.mwnci pwd.mwnci sysstat.mwnci units.mwnci \
	ansicolor.mwnci
INCLUDEDIR=@INCLUDE@
INSTALL=install
OWNER=@OWNER@
GROUP=@GROUP@

dummy:

install: ${FILES}
	mkdir -p ${INCLUDEDIR}
	cp ${FILES} ${INCLUDEDIR}
	sudo chmod 755 ${INCLUDEDIR}
	sudo chmod 644 ${INCLUDEDIR}/*.mwnci
clean:
	rm -f *~ \#*\#	

