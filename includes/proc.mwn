function getload() {
    return fields(cat("/proc/loadavg"));
};

function meminfo() {
    memdata=split(cat("/proc/meminfo"), "\n")
    memdata_hash={}
    foreach line in memdata {
        label=trim(split(line, ":")[0])
	    label=label.replaceall("(", "_")
	    label=split(label, ")")[0]
	    data=split(line, ":")[1]
	    data=fields(trim(data))[0]
	    memdata_hash=set(memdata_hash, label, data)
    }
    return memdata_hash;
};
